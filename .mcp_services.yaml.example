# MCP Service Configuration Profiles
# Copy to .mcp_services.yaml and customize for your services
#
# NEW: Each profile can now contain MULTIPLE MCP servers!
# This allows you to:
# - Group MCPs by environment (dev/staging/prod)
# - Group MCPs by workflow (data-pipeline, analytics, etc.)
# - Mix different MCP servers in one profile for your use case
#
# Security Notes:
# - Keep secrets in environment variables (referenced with ${VAR_NAME})
# - Add .mcp_services.yaml to .gitignore if it contains sensitive data
# - For team sharing, use .mcp_services.yaml.example with ${} placeholders

# Default profile (used when no --profile specified)
# Can also mark a profile as default using "default: true" within the profile
default: local-dev

# Profile definitions
profiles:
  # Profile for local development with multiple MCPs
  local-dev:
    name: "Local Development"
    description: "Local MCP servers for development"
    mcps:
      - name: "Superset MCP"
        mcp_url: "http://localhost:5008/mcp/"
        auth:
          type: "bearer"
          token: "${SUPERSET_MCP_TOKEN}"

      - name: "Database MCP"
        mcp_url: "http://localhost:5009/mcp/"
        auth:
          type: "none"

      - name: "AI Assistant MCP"
        mcp_url: "http://localhost:5010/mcp/"
        auth:
          type: "bearer"
          token: "${AI_MCP_TOKEN}"

  # Single MCP profile (backward compatible)
  local-simple:
    name: "Local Simple"
    description: "Single MCP server for testing"
    mcps:
      - name: "Superset Local"
        mcp_url: "http://localhost:5008/mcp/"
        auth:
          type: "none"

  # Profile for staging with different MCPs
  staging:
    name: "Staging Environment"
    description: "Staging servers for integration testing"
    default: true  # Mark this profile as default (auto-selected in UI)
    mcps:
      - name: "Superset Staging"
        mcp_url: "https://staging.example.com/mcp/"
        auth:
          type: "jwt"
          api_url: "https://staging.example.com/v1/auth/"
          api_token: "${STAGING_API_TOKEN}"
          api_secret: "${STAGING_API_SECRET}"

      - name: "Analytics MCP"
        mcp_url: "https://analytics-staging.example.com/mcp/"
        auth:
          type: "bearer"
          token: "${ANALYTICS_STAGING_TOKEN}"

  # Profile for production
  prod:
    name: "Production"
    description: "Production MCP servers"
    mcps:
      - name: "Superset Production"
        mcp_url: "https://api.example.com/mcp/"
        auth:
          type: "jwt"
          api_url: "https://api.example.com/v1/auth/"
          api_token: "${PROD_API_TOKEN}"
          api_secret: "${PROD_API_SECRET}"

      - name: "Analytics Production"
        mcp_url: "https://analytics.example.com/mcp/"
        auth:
          type: "oauth"
          client_id: "${PROD_ANALYTICS_CLIENT_ID}"
          client_secret: "${PROD_ANALYTICS_CLIENT_SECRET}"
          token_url: "https://analytics.example.com/oauth/token"
          scopes: ["mcp:read", "mcp:write"]

  # Custom workflow profile - mix of different MCPs
  data-pipeline:
    name: "Data Pipeline Testing"
    description: "MCPs needed for data pipeline workflows"
    mcps:
      - name: "Superset Local"
        mcp_url: "http://localhost:5008/mcp/"
        auth:
          type: "none"

      - name: "Airbyte MCP"
        mcp_url: "https://airbyte.example.com/mcp/"
        auth:
          type: "bearer"
          token: "${AIRBYTE_TOKEN}"

      - name: "DBT MCP"
        mcp_url: "https://dbt.example.com/mcp/"
        auth:
          type: "oauth"
          client_id: "${DBT_CLIENT_ID}"
          client_secret: "${DBT_CLIENT_SECRET}"
          token_url: "https://dbt.example.com/oauth/token"
          scopes: ["dbt:read", "dbt:execute"]

  # Customer-specific profile
  customer-acme:
    name: "Acme Corp"
    description: "Acme customer deployment"
    mcps:
      - name: "Acme Superset"
        mcp_url: "https://acme.example.com/mcp/"
        auth:
          type: "bearer"
          token: "${ACME_MCP_TOKEN}"

      - name: "Acme Data Lake"
        mcp_url: "https://acme-data.example.com/mcp/"
        auth:
          type: "bearer"
          token: "${ACME_DATA_TOKEN}"

# Optional: Global settings applied to all profiles
global:
  # Default timeout for requests (seconds)
  timeout: 30

  # Rate limiting
  rate_limit:
    requests_per_minute: 60

  # Retry configuration
  retry:
    max_attempts: 3
    backoff_multiplier: 2
