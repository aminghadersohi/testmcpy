# MCP Testing Configuration Example
# Copy this to .env and customize your settings

# Default model to use for testing
DEFAULT_MODEL=qwen2.5:14b

# Default provider (ollama, openai, local)
DEFAULT_PROVIDER=ollama

# MCP service URL
MCP_URL=http://localhost:5008/mcp/

# Ollama base URL (if using ollama provider)
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI API key (if using openai provider)
# OPENAI_API_KEY=your-api-key-here