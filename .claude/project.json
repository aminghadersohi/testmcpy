{
  "name": "MCP Testing Framework",
  "description": "A comprehensive testing framework for validating LLM tool calling capabilities with MCP (Model Context Protocol) services, specifically designed for testing Superset operations.",
  "version": "1.0.0",
  "type": "python",
  "framework": "cli",
  "dependencies": {
    "python": ">=3.8",
    "typer": "CLI framework",
    "rich": "Terminal output formatting",
    "pyyaml": "YAML parsing",
    "requests": "HTTP client",
    "aiohttp": "Async HTTP client"
  },
  "structure": {
    "src/": "Core framework modules",
    "evals/": "Evaluation functions",
    "tests/": "Test case definitions",
    "reports/": "Generated test reports",
    "my_mcp_tests/": "Example configurations",
    "research/": "Research scripts",
    "cli.py": "Main CLI interface"
  },
  "key_files": [
    "cli.py",
    "src/mcp_client.py",
    "src/llm_integration.py",
    "src/test_runner.py",
    "evals/base_evaluators.py",
    "README.md",
    "requirements.txt"
  ],
  "testing": {
    "framework": "custom",
    "test_files": "tests/*.yaml",
    "run_command": "python cli.py run tests/"
  },
  "development": {
    "entry_point": "cli.py",
    "local_models": ["llama3.1:8b", "mistral-nemo", "qwen2.5:7b"],
    "mcp_services": "http://localhost:5008/mcp"
  }
}